{
  "name": "velo-admin-backend",
  "version": "1.0.0",
  "description": "Admin backend for VELO ride-hailing application",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node index.ts",
    "build": "tsc",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ryde-backend",
    "pm2:restart": "pm2 restart ryde-backend",
    "pm2:logs": "pm2 logs ryde-backend",
    "deploy": "npm run build && pm2 start ecosystem.config.js --env production",
    "repair:ride-permissions": "ts-node repair-assigned-ride-permissions.ts",
    "migrate:admin-schema": "ts-node migrate-admin-schema.ts"
  },
  "dependencies": {
    "@sentry/node": "^10.51.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "node-appwrite": "^24.0.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "@types/pino-http": "^5.8.4",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
