# Copy this to backend/.env and fill in real values
# See docs/ENVIRONMENT.md for details

APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_DATABASE_ID=your_database_id
APPWRITE_API_KEY=your_server_api_key

ADMIN_API_TOKEN=generate_random_64_char_hex
ADMIN_EMAIL=admin@ryde.local
ADMIN_PASSWORD=generate_strong_password
ADMIN_NAME=RYDE Admin
ADMIN_ALLOWED_ORIGINS=https://your-admin-domain.netlify.app,http://localhost:5173

PORT=3000
